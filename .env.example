# --- OpenAI-compatible LLM (e.g. Berget.AI) ---
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.berget.ai/v1
OPENAI_MODEL=gemma-3-27b-it
# Optional: a separate, stronger model for reflection (defaults to OPENAI_MODEL)
REFLECTION_MODEL=

# --- Embeddings (OpenAI-compatible /embeddings endpoint) ---
# If unset OR the endpoint fails, the agent falls back to a deterministic
# hashed bag-of-words vector (good enough for the lab-scale corpus).
EMBED_MODEL=

# --- Brave Web Search ---
BRAVE_API_KEY=

# --- Runtime tuning ---
REFLECT_EVERY=3        # trigger reflection after this many new episodes
TOP_K_EPISODES=3
TOP_K_INSIGHTS=5
MAX_TOOL_ITERS=6
